{
  "title": "Application Health",
  "uid": "app-health-v1",
  "description": "Real-time health and performance for the observability-app NestJS service. Powered by OpenTelemetry metrics scraped by Prometheus.",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "tags": ["observability", "nestjs", "otel"],
  "graphTooltip": 1,
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "links": [],
  "panels": [

    {
      "id": 1,
      "type": "stat",
      "title": "Requests / sec",
      "description": "Current request throughput. PromQL: rate() on a counter gives per-second increase. sum() collapses all label dimensions into one number.",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum(rate(otel_http_client_duration_milliseconds_count{exported_job=\"observability-app\"}[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null },
              { "color": "green", "value": 0.1 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      }
    },

    {
      "id": 2,
      "type": "stat",
      "title": "Error Rate %",
      "description": "Percentage of requests returning HTTP 5xx. Built by dividing the 5xx rate by the total rate. Thresholds: green < 5%, yellow < 15%, red >= 15%.",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "100 * sum(rate(otel_http_client_duration_milliseconds_count{exported_job=\"observability-app\", http_status_code=~\"5..\"}[1m])) / sum(rate(otel_http_client_duration_milliseconds_count{exported_job=\"observability-app\"}[1m]))",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      }
    },

    {
      "id": 3,
      "type": "stat",
      "title": "p95 Latency",
      "description": "95th percentile request latency. Computed via histogram_quantile() over the _bucket series. 'sum by(le)' aggregates all bucket counters before quantile estimation.",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(otel_http_client_duration_milliseconds_bucket{exported_job=\"observability-app\"}[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 1,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      }
    },

    {
      "id": 4,
      "type": "stat",
      "title": "Event Loop p99 Delay",
      "description": "Node.js event loop lag at the 99th percentile. This is the key indicator of a blocked event loop — high values mean your JS thread is busy and can't process I/O callbacks promptly. Multiplied by 1000 to convert seconds → ms.",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "otel_nodejs_eventloop_delay_p99_seconds * 1000",
          "legendFormat": "p99 ms"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "area",
        "textMode": "auto",
        "justifyMode": "center"
      }
    },

    {
      "id": 5,
      "type": "timeseries",
      "title": "Request Throughput by Status Code",
      "description": "Rate of HTTP requests per second, broken down by HTTP status code. Each coloured line is one status code (200, 302, 500, etc.). 'sum by(http_status_code)' retains that label dimension instead of collapsing everything into one line.",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum by(http_status_code) (rate(otel_http_client_duration_milliseconds_count{exported_job=\"observability-app\"}[1m]))",
          "legendFormat": "HTTP {{http_status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "A" },
            "properties": []
          },
          {
            "matcher": { "id": "byName", "options": "HTTP 500" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "HTTP 200" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 6,
      "type": "timeseries",
      "title": "5xx Error Rate over Time",
      "description": "Per-second rate of server errors over time. A flat line at 0 is healthy. Spikes correspond to the simulator hitting the /users/7 and /users/13 endpoints that intentionally return 500s in the AppController.",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "sum(rate(otel_http_client_duration_milliseconds_count{exported_job=\"observability-app\", http_status_code=~\"5..\"}[1m]))",
          "legendFormat": "5xx errors/s"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "fixedColor": "red", "mode": "fixed" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 20,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.01 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "single" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 7,
      "type": "timeseries",
      "title": "Latency Percentiles (p50 / p95 / p99)",
      "description": "Three percentile lines computed from the same histogram. p50 = median (half of requests are faster). p95 = 95% of requests finish within this time. p99 = your 'worst case for most users'. The gap between p95 and p99 reveals outlier spikes. The [5m] range is intentionally wider than [1m] so the quantile estimator has enough data points.",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.50, sum by(le) (rate(otel_http_client_duration_milliseconds_bucket{exported_job=\"observability-app\"}[5m])))",
          "legendFormat": "p50 (median)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.95, sum by(le) (rate(otel_http_client_duration_milliseconds_bucket{exported_job=\"observability-app\"}[5m])))",
          "legendFormat": "p95"
        },
        {
          "refId": "C",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "histogram_quantile(0.99, sum by(le) (rate(otel_http_client_duration_milliseconds_bucket{exported_job=\"observability-app\"}[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "p99" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p95" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "p50 (median)" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 8,
      "type": "timeseries",
      "title": "Node.js Event Loop Delay",
      "description": "How long Node.js tasks wait in the event loop queue before being processed (p50 and p99). This is a gauge — queried directly, no rate() needed. Healthy apps stay well under 10ms. Spikes indicate CPU-intensive work blocking the JS thread.",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "otel_nodejs_eventloop_delay_p50_seconds * 1000",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "otel_nodejs_eventloop_delay_p99_seconds * 1000",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "decimals": 2,
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    },

    {
      "id": 9,
      "type": "timeseries",
      "title": "Heap Memory — Used vs Limit",
      "description": "V8 heap memory usage over time. Two lines: 'used' (actual allocation) and 'limit' (the maximum V8 will allow before OOMing). The gap between them is your memory headroom. A 'used' line creeping toward 'limit' indicates a memory leak. Unit: bytes — Grafana converts to MB/GB automatically.",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus-local" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "otel_v8js_memory_heap_used_bytes",
          "legendFormat": "Heap Used"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus-local" },
          "expr": "otel_v8js_memory_heap_limit_bytes",
          "legendFormat": "Heap Limit"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "spanNulls": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Heap Limit" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } },
              { "id": "custom.lineStyle", "value": { "dash": [10, 10], "fill": "dash" } },
              { "id": "custom.fillOpacity", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Heap Used" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "blue", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      }
    }

  ]
}
